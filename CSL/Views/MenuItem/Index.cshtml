@{
    ViewData["Title"] = "Menu Principal";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-list-ul me-2"></i>Menu Principal</h4>
    <button class="btn btn-primary" onclick="abrirModalNuevo()">
        <i class="bi bi-plus-lg me-1"></i>Nuevo Item
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div id="divLoading" class="text-center py-4" style="display:none !important;">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
        <div id="divTablaMenuItems"></div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modalMenuItem" tabindex="-1" aria-labelledby="modalMenuItemLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalMenuItemLabel">Item de Menu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formMenuItem">
                    <input type="hidden" id="hdfIdMenuItem" value="0" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="txtEtiqueta">Etiqueta <span class="text-danger">*</span></label>
                        <input type="text" id="txtEtiqueta" class="form-control" maxlength="100" placeholder="Ej: Inicio" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="txtUrlDestino">URL Destino <span class="text-danger">*</span></label>
                        <input type="text" id="txtUrlDestino" class="form-control" maxlength="300" placeholder="Ej: #inicio" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="txtOrden">Orden</label>
                        <input type="number" id="txtOrden" class="form-control" min="0" value="0" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="guardarMenuItem()">
                    <i class="bi bi-save me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="hdfOculto" value="@Url.Content("~/")" />

@section Scripts {
    <script src="~/js/Generic.js" asp-append-version="true"></script>
    <script src="~/js/menuItem.js" asp-append-version="true"></script>
}
